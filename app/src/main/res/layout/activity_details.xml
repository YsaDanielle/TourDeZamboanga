<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sunset_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/back_button_bg"
        android:contentDescription="Back"
        android:elevation="8dp"
        android:padding="13dp"
        android:scaleType="center"
        android:src="@drawable/ic_arrow_back_24"
        android:tint="@color/vinta_red"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/detailLogo"
        android:layout_width="190dp"
        android:layout_height="78dp"
        android:layout_marginTop="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/detailLogoTourDe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:includeFontPadding="false"
                android:text="Tour de"
                android:textColor="#5F0200"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/detailLogoZamboanga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-18dp"
                android:fontFamily="@font/great_vibes"
                android:includeFontPadding="false"
                android:text="Zamboanga"
                android:textColor="#FD3000"
                android:textSize="40sp"
                android:elevation="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/detailLogoTourDe" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/detailImageCard"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginStart="38dp"
        android:layout_marginTop="-18dp"
        android:layout_marginEnd="38dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/detailLogo">

        <ImageView
            android:id="@+id/detailImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/blurrycityhall" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/detailSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_white_top_85"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingTop="24dp"
        android:paddingEnd="30dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/detailImageCard">

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:includeFontPadding="false"
                android:text="LANDMARK"
                android:textColor="@color/text"
                android:textSize="32sp"
                android:shadowColor="#55000000"
                android:shadowDx="2"
                android:shadowDy="3"
                android:shadowRadius="3" />

            <TextView
                android:id="@+id/detailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Location"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Landmark(s)"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailLandmarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Opening Hours"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Activities"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailActivities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Services"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Estimated Costs"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/detailEstimatedCosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp"
                android:text="Description goes here..."
                android:textColor="#5F6368"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/poppins_bold"
                android:text="View on Map"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="@color/vinta_red"
                app:cornerRadius="30dp" />

    </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
